# Server
PORT=5001
CLIENT_ORIGIN=http://localhost:5173

# MongoDB Atlas — sign up free at https://www.mongodb.com/cloud/atlas
# Create a free cluster, get your connection string, and paste it below
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/dearte?retryWrites=true&w=majority

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_generate_new_one
JWT_REFRESH_SECRET=your_refresh_secret_here_generate_new_one

# Cloudinary — sign up free at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# WhatsApp Cloud API (Meta Developer App — WhatsApp product)
# Create an app → WhatsApp → API Setup: copy Phone number ID and a System User permanent token or temporary token (rotate in production).
# https://developers.facebook.com/docs/whatsapp/cloud-api
WHATSAPP_ENABLED=true
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Graph API version for graph.facebook.com/<version>; keep in sync with your Meta app.
WHATSAPP_API_VERSION=v21.0
# When buyer mobile lacks country code (e.g. 10-digit India), prepend this digits-only prefix:
WHATSAPP_DEFAULT_COUNTRY_CODE=91
# Comma-separated E.164-style numbers WITHOUT + ; receive order-placed PDFs (alongside Dashboard field whatsappOperationsNumbers).
WHATSAPP_ADMIN_NUMBERS=
# Optional delay ms between outbound broadcast recipients to reduce throttling:
WHATSAPP_SEND_DELAY_MS=350
# For local testing with ngrok, use the public HTTPS tunnel URL in Meta webhook config:
#   https://<your-ngrok-subdomain>.ngrok-free.app/api/whatsapp/webhook
# For production, replace it with your live HTTPS domain:
#   https://<your-domain>/api/whatsapp/webhook
# Create the same token in the Meta developer console and keep it matched here:
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Frontend
VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=http://localhost:5001
