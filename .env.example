# Server
PORT=5001

# MUST be set to "production" on your deployment host. When it is not,
# session cookies are not marked Secure and loopback CORS origins are accepted.
NODE_ENV=production

# The exact scheme+host+port of the storefront. Used as the CORS allow-list;
# origins that are not listed here are refused.
CLIENT_ORIGIN=http://localhost:5180
# Optional comma-separated extra origins (e.g. a preview deployment):
# ADDITIONAL_CLIENT_ORIGINS=https://staging.example.com,https://www.example.com

# MongoDB Atlas — sign up free at https://www.mongodb.com/cloud/atlas
# Create a free cluster, get your connection string, and paste it below
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/dearte?retryWrites=true&w=majority

# JWT — generate each with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Required in production. The API refuses to start if these are missing, shorter
# than 32 characters, left at a placeholder value, or identical to each other.
JWT_SECRET=your_jwt_secret_here_generate_new_one
JWT_REFRESH_SECRET=your_refresh_secret_here_generate_new_one

# Initial admin account, created only on the very first boot against an empty
# database. Required in production: the API refuses to seed the built-in
# "Admin@123" default. Must be 8+ chars with at least one letter and one number.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# Cloudinary — sign up free at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# WhatsApp Cloud API (Meta Developer App — WhatsApp product)
# Create an app → WhatsApp → API Setup: copy Phone number ID and a System User permanent token or temporary token (rotate in production).
# https://developers.facebook.com/docs/whatsapp/cloud-api
WHATSAPP_ENABLED=true
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Graph API version for graph.facebook.com/<version>; keep in sync with your Meta app.
WHATSAPP_API_VERSION=v21.0
# When buyer mobile lacks country code (e.g. 10-digit India), prepend this digits-only prefix:
WHATSAPP_DEFAULT_COUNTRY_CODE=91
# Comma-separated E.164-style numbers WITHOUT + ; receive order-placed PDFs (alongside Dashboard field whatsappOperationsNumbers).
WHATSAPP_ADMIN_NUMBERS=
# Optional delay ms between outbound broadcast recipients to reduce throttling:
WHATSAPP_SEND_DELAY_MS=350
# For local testing with ngrok, use the public HTTPS tunnel URL in Meta webhook config:
#   https://<your-ngrok-subdomain>.ngrok-free.app/api/whatsapp/webhook
# For production, replace it with your live HTTPS domain:
#   https://<your-domain>/api/whatsapp/webhook
# Create the same token in the Meta developer console and keep it matched here:
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Email (Nodemailer over SMTP — Gmail by default)
# EMAIL_PASSWORD must be a Gmail App Password (16 chars), NOT your account password.
# Requires 2-Step Verification, then generate at https://myaccount.google.com/apppasswords (pick "Mail").
EMAIL_ENABLED=true
EMAIL_USER=you@gmail.com
EMAIL_PASSWORD=
# Optional. Defaults to EMAIL_USER. Use a display name + address: "De Arté <you@gmail.com>"
EMAIL_FROM=De Arté <you@gmail.com>
# Comma-separated admin emails copied on every new order (alongside Dashboard field orderNotificationEmails).
EMAIL_ADMIN_RECIPIENTS=
# Optional delay ms between outbound broadcast recipients to reduce throttling:
EMAIL_SEND_DELAY_MS=400
# SMTP overrides (defaults are Gmail SSL). Leave as-is for Gmail; change for SES/Zoho/etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true

# Frontend
VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=http://localhost:5001
